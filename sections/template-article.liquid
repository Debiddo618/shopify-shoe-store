{% for block in section.blocks %}
    {% case block.type %}
        {% when 'article_title' %}
            <h1>{{ article.title }}</h1>
        {% when 'article_author' %}
            <small>{{ article.author }}</small>
        {% when 'article_published_date' %}
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%Y-%m-%d' }}</time>
        {% when 'featured_image' %}
            <img src="{{ article.image | image_url: width: 800, height: 600 }}" alt="{{ article.image.alt }}">
        {% when 'article_content' %}
            <div>{{ article.content }}</div>
    {% endcase %}
{% endfor %}

{% schema %}
    {
        "name":"Template Article",
        "settings": [
            {
                "type": "checkbox",
                "id": "enable_author",
                "default":true,
                "label": "Display Author Name"
            },
            {
                "type": "checkbox",
                "id": "enable_published_date",
                "default": true,
                "label": "Display published date"
            }
        ],
        "blocks": [
            {
                "type": "article_title",
                "name":"Title",
                "limit": 1
            },
            {
                "type": "article_author",
                "name":"Arthor",
                "limit": 1
            },
            {
                "type": "article_published_date",
                "name":"Published Date",
                "limit": 1
            },
            {
                "type": "featured_image",
                "name":"Thumbnail",
                "limit": 1
            },
            {
                "type": "article_content",
                "name":"Content",
                "limit": 1
            },
        ]
    }
{% endschema %}